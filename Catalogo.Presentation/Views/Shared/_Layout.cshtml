<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 🎌 Mi Catálogo Anime</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="anime-navbar">
            <div class="nav-inner">
                <a class="nav-brand" asp-controller="Home" asp-action="Index">🎌 AnimeVault</a>
                <div class="nav-links">
                    <a asp-controller="Catalogo" asp-action="Index">📋 Catálogo</a>
                    <a asp-controller="Catalogo" asp-action="Agregar">➕ Agregar</a>
                    <a asp-controller="Home" asp-action="Privacy">🔒 Privacidad</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="anime-footer">
        <p>🎌 AnimeVault &copy; 2026 — Hecho con ❤️ para otakus</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>